# ============================================================
#  SOC Xpert · Sec4data — configuração de ambiente
#  Copia este ficheiro para .env e preenche conforme o teu stack.
#    cp .env.example .env
# ============================================================

# Porta exposta no host
PORT=4000

# Origem dos dados:
#   true  → DEMO (dados simulados, arranca sem dependências)
#   false → LIVE (usa os conectores configurados abaixo)
DEMO_MODE=true

# CORS — em produção restringe ao teu domínio, ex: https://soc.sec4data.com
CORS_ORIGIN=*

# ============================================================
#  Autenticação e produção (sub-fase 03.2)
# ============================================================
# Ambiente. Em "production": cookies Secure por defeito, avisos de postura e
# recusa de arrancar com APP_ENCRYPTION_KEY por defeito quando há base de dados.
# (No Docker já vem NODE_ENV=production.)
NODE_ENV=development

# O login torna-se OBRIGATÓRIO automaticamente quando existe um administrador
# (ADMIN_PASSWORD abaixo, ou utilizadores na base de dados). Para forçar: true.
AUTH_REQUIRED=false

# Cookies de sessão Secure (HTTPS). Liga em produção atrás de TLS.
COOKIE_SECURE=false
# Duração da sessão, em horas.
SESSION_TTL_HOURS=12

# Atrás de um reverse proxy (Nginx/Traefik a terminar TLS): 1 = confia no 1º salto.
# Necessário para cookies Secure e IP real. Em produção assume 1 por defeito.
# TRUST_PROXY=1

# Content-Security-Policy ativa por defeito; só desliga se souberes o que fazes.
# CSP_DISABLED=false

# ============================================================
#  Fase 03 · Base de dados e identidade
#  (No docker-compose, a base de dados Postgres é criada por ti.
#   Sem DATABASE_URL, a app corre em modo legado, como antes.)
# ============================================================

# Ligação à base de dados PostgreSQL.
# Com docker-compose isto é definido automaticamente; só precisas
# de definir POSTGRES_PASSWORD. Fora do compose, preenche a URL completa.
POSTGRES_PASSWORD=socx
# DATABASE_URL=postgresql://socx:socx@localhost:5432/socxpert?schema=public

# Chave de cifragem das credenciais dos conectores (AES-256-GCM).
# Gera uma forte com:  openssl rand -base64 32
APP_ENCRYPTION_KEY=troca-esta-chave-por-uma-de-32-bytes

# Tenant (organização) por defeito, criado no primeiro arranque.
DEFAULT_TENANT_SLUG=sec4data
DEFAULT_TENANT_NAME=Sec4data

# Administrador inicial. O seed só cria o admin se definires a palavra-passe.
ADMIN_EMAIL=admin@sec4data.com
ADMIN_NAME=Administrador
ADMIN_PASSWORD=

# Executar o seed no arranque (tenant + admin + conectores do .env). true/false
RUN_SEED=true


# ──────────────── Wazuh ────────────────
# API do manager (saúde + agentes) — normalmente porta 55000
WAZUH_API_URL=
WAZUH_API_USER=
WAZUH_API_PASSWORD=
# Indexer / OpenSearch (pesquisa de alertas) — normalmente porta 9200
WAZUH_INDEXER_URL=
WAZUH_INDEXER_USER=
WAZUH_INDEXER_PASSWORD=
WAZUH_ALERTS_INDEX=wazuh-alerts-*
# Aceitar certificados self-signed (laboratório). Em produção com TLS válido: false
WAZUH_INSECURE_TLS=true

# ──────────────── MISP ─────────────────
MISP_URL=
MISP_API_KEY=
MISP_INSECURE_TLS=true

# ─────────────── TheHive ───────────────
THEHIVE_URL=
THEHIVE_API_KEY=
THEHIVE_INSECURE_TLS=true

# ───────── Copilot (Anthropic) ─────────
# Sem chave, o Copilot funciona em modo fallback (respostas locais).
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# ════════ Ingestão de syslog das firewalls ════════
# As firewalls (OPNsense, pfSense, FortiGate, Cisco ASA, Palo Alto…) enviam
# logs por syslog para esta aplicação. Aponta a firewall para o IP deste host.
#
# No docker-compose, o host recebe na porta 514 (padrão) e encaminha para 5514
# dentro do contentor. Para mudar a porta do host: SYSLOG_HOST_PORT=1514
SYSLOG_ENABLED=true
SYSLOG_UDP=true
SYSLOG_TCP=true
SYSLOG_HOST_PORT=514
SYSLOG_MAX_EVENTS=2000
# Mapeamento opcional IP da firewall → tenant (multitenancy chega em 03.5):
#   SYSLOG_TENANT_MAP=10.0.0.1=cliente-a,10.0.0.2=cliente-b
SYSLOG_TENANT_MAP=

# ════════ Webhook de entrada (integração universal) ════════
# Qualquer solução externa (SIEM, EDR, WAF, automação, API de parceiro…) pode
# enviar eventos JSON por HTTP POST para /api/ingest/webhook, autenticando com
# este token (cabeçalho X-SOCX-Token, ou ?token=). Sem token, fica desativado.
# Gere um token forte:  openssl rand -hex 24
WEBHOOK_TOKEN=
WEBHOOK_MAX_EVENTS=2000
